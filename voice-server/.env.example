# Voice WebSocket Server
VOICE_WS_PORT=8080

# Twilio (used by Next.js webhooks, not directly by voice-server)
TWILIO_ACCOUNT_SID=ACxxxxxx
TWILIO_AUTH_TOKEN=

# Deepgram STT (Nova-3)
DEEPGRAM_API_KEY=

# ElevenLabs TTS (Flash v2.5)
ELEVENLABS_API_KEY=

# AWS Bedrock (Claude Haiku 4.5 + Titan Embeddings)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Pinecone (RAG - optional, RAG disabled if not set)
PINECONE_API_KEY=
PINECONE_CHATBOT_INDEX_NAME=leadbotstudio-embeddings

# Database (shared with main app)
DATABASE_URL=postgresql://...

# Voice WebSocket URL (used by Next.js Twilio webhook to point calls here)
VOICE_WS_URL=wss://voice-ws.yourdomain.com
